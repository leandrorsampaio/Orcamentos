{
  "name": "orcamentos",
  "version": "1.0.0",
  "private": true,
  "description": "Sistema de Orçamentos — LVI Planejados / Stilus Decora",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "vite build",
    "check": "tsc --noEmit",
    "deploy": "vite build && wrangler deploy",
    "db:local": "wrangler d1 execute orcamentos-db --local --file=./migrations/0001_init.sql",
    "db:remote": "wrangler d1 execute orcamentos-db --remote --file=./migrations/0001_init.sql"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "wrangler": "^4.107.0"
  }
}
